# Chakra CRM/page scraper runtime config.
# Never commit .env or playwright/.auth/* files.

CHAKRA_LOGIN_URL="https://chakra.example.com/login"
CHAKRA_DEFAULT_LIST_URL="https://chakra.example.com/leads"
CHAKRA_ALLOWED_HOSTS="chakra.example.com"
CHAKRA_STATE_PATH="playwright/.auth/chakra_state.json"
CHAKRA_OUTPUT_DIR="output"
CHAKRA_HEADLESS="true"
CHAKRA_SLOW_MO_MS="0"
CHAKRA_TIMEOUT_MS="30000"
CHAKRA_NAVIGATION_TIMEOUT_MS="45000"
CHAKRA_MIN_DELAY_MS="700"
CHAKRA_MAX_DELAY_MS="1800"
CHAKRA_MAX_RETRIES="2"
CHAKRA_LOG_LEVEL="INFO"
